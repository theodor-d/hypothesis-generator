@page
@model HypothesisGenerator.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- =====================================================
     Index Page — Main input form
     ===================================================== -->
<!-- Hero Section -->
<div class="text-center my-5">
    <h1 class="display-5 fw-bold mb-3">
        <span class="gradient-text">Research Hypothesis Generator</span>
    </h1>
    <p class="text-secondary fs-5 mb-0" style="max-width: 580px; margin: 0 auto;">
        Enter any research topic and get 5 AI-generated, testable hypotheses
        complete with methodology and difficulty ratings.
    </p>
</div>

<!-- Error Message (shown if something went wrong) -->
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>@Model.ErrorMessage</div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Main Input Card -->
<div class="card shadow-lg mx-auto" style="max-width: 720px;">
    <div class="card-body p-4 p-md-5">

        <!-- Form uses POST to send data back to Index.cshtml.cs -->
        <form method="post" onsubmit="showLoading()">

            <!-- Research Topic Textarea -->
            <div class="mb-4">
                <label class="form-label fw-semibold fs-6 mb-2" for="topic">
                    <i class="bi bi-journal-text me-1" style="color: var(--accent);"></i>
                    Research Topic
                </label>
                <textarea id="topic"
                          name="Topic"
                          class="form-control"
                          rows="3"
                          placeholder="e.g. social media and sleep quality, caffeine and academic performance..."
                          maxlength="300"
                          required>@Model.Request.Topic</textarea>
                <div class="form-text text-secondary mt-1">
                    <i class="bi bi-info-circle me-1"></i>
                    Be specific! E.g., "screen time before bed and sleep quality in teenagers"
                </div>
            </div>

            <!-- Difficulty Filter Dropdown -->
            <div class="mb-4">
                <label class="form-label fw-semibold fs-6 mb-2" for="difficultyFilter">
                    <i class="bi bi-bar-chart-fill me-1" style="color: var(--accent);"></i>
                    Difficulty Level
                </label>
                <select id="difficultyFilter"
                        name="DifficultyFilter"
                        class="form-select">
                    <option value="Mixed" selected="@(Model.Request.DifficultyFilter == "Mixed")">
                        🎯 Mixed (Recommended) — 2 Beginner, 2 Intermediate, 1 Advanced
                    </option>
                    <option value="Beginner" selected="@(Model.Request.DifficultyFilter == "Beginner")">
                        🟢 Beginner — Simple, straightforward hypotheses
                    </option>
                    <option value="Intermediate" selected="@(Model.Request.DifficultyFilter == "Intermediate")">
                        🟡 Intermediate — Moderate complexity
                    </option>
                    <option value="Advanced" selected="@(Model.Request.DifficultyFilter == "Advanced")">
                        🔴 Advanced — Complex, multi-variable hypotheses
                    </option>
                </select>
            </div>

            <!-- Submit Button -->
            <div class="d-grid mb-3">
                <button type="submit" class="btn btn-generate btn-lg">
                    <i class="bi bi-stars me-2"></i>Generate Hypotheses
                </button>
            </div>

        </form>

        <!-- Divider -->
        <hr style="border-color: var(--border);" />

        <!-- Example Topic Buttons -->
        <div>
            <p class="text-secondary small mb-3 fw-semibold text-uppercase" style="letter-spacing: 0.05em;">
                <i class="bi bi-lightning-charge-fill me-1" style="color: #fbbf24;"></i>
                Try an example topic:
            </p>
            <div class="d-flex flex-wrap gap-2">
                <!-- Each button fills in the textarea via JavaScript -->
                <button class="btn btn-example btn-sm"
                        onclick="setTopic('social media use and mental health in university students')">
                    📱 Social media & mental health
                </button>
                <button class="btn btn-example btn-sm"
                        onclick="setTopic('caffeine consumption and academic performance')">
                    ☕ Caffeine & academic performance
                </button>
                <button class="btn btn-example btn-sm"
                        onclick="setTopic('exercise frequency and stress levels in office workers')">
                    🏃 Exercise & stress levels
                </button>
                <button class="btn btn-example btn-sm"
                        onclick="setTopic('gamification and student motivation in online learning')">
                    🎮 Gamification & learning
                </button>
            </div>
        </div>

    </div>
</div>

<div class="mx-auto mt-4" style="max-width: 720px;">
    <div class="row g-3 text-center">
        <div class="col-md-4">
            <div class="card h-100 p-3">
                <div class="fs-2 mb-2">🎯</div>
                <div class="fw-semibold small">Be Specific</div>
                <div class="text-secondary" style="font-size:0.8rem;">
                    Include who, what, and where for better results
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-3">
                <div class="fs-2 mb-2">📊</div>
                <div class="fw-semibold small">Get Methodology</div>
                <div class="text-secondary" style="font-size:0.8rem;">
                    Each hypothesis comes with a suggested research method
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 p-3">
                <div class="fs-2 mb-2">🔁</div>
                <div class="fw-semibold small">Regenerate Freely</div>
                <div class="text-secondary" style="font-size:0.8rem;">
                    Each run produces different creative hypotheses
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function setTopic(text) {
            document.getElementById('topic').value = text;
            document.getElementById('topic').focus();
        }
    </script>
}