<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Hypothesis Generator</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />

    <style>
            :root {
                --accent: #6ea8fe;
                --accent-soft: #1a2942;
                --surface: #1e1e2e;
                --surface-2: #2a2a3e;
                --border: #3a3a5c;
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: #13131f;
                color: #e0e0f0;
                min-height: 100vh;
            }

            .navbar-brand span.brand-icon {
                font-size: 1.4rem;
            }

            .navbar-brand span.brand-text {
                font-family: 'Playfair Display', serif;
                font-size: 1.25rem;
                letter-spacing: 0.01em;
            }

            .card {
                background-color: var(--surface);
                border: 1px solid var(--border);
                border-radius: 16px;
            }

            .hypothesis-card {
                background-color: var(--surface-2);
                border: 1px solid var(--border);
                border-radius: 12px;
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }

                .hypothesis-card:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 8px 24px rgba(0,0,0,0.4);
                }

            .hypothesis-number {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                background: linear-gradient(135deg, #6ea8fe, #a78bfa);
                display: flex;
                align-items: center;
                justify-content: center;
                font-weight: 700;
                font-size: 1.1rem;
                flex-shrink: 0;
            }

            .badge-beginner {
                background-color: #198754;
            }

            .badge-intermediate {
                background-color: #ffc107;
                color: #000;
            }

            .badge-advanced {
                background-color: #dc3545;
            }

            .btn-generate {
                background: linear-gradient(135deg, #6ea8fe, #a78bfa);
                border: none;
                color: #fff;
                font-weight: 600;
                padding: 0.75rem 2rem;
                border-radius: 50px;
                font-size: 1.05rem;
                transition: opacity 0.2s;
            }

                .btn-generate:hover {
                    opacity: 0.9;
                    color: #fff;
                }

                .btn-generate:active {
                    opacity: 0.8;
                }

            .btn-example {
                background-color: var(--accent-soft);
                border: 1px solid var(--border);
                color: var(--accent);
                border-radius: 50px;
                font-size: 0.875rem;
                transition: background-color 0.2s;
            }

                .btn-example:hover {
                    background-color: #243557;
                    color: var(--accent);
                }

            .gradient-text {
                background: linear-gradient(135deg, #6ea8fe, #a78bfa, #f472b6);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

            textarea.form-control, select.form-select {
                background-color: var(--surface-2);
                border-color: var(--border);
                color: #e0e0f0;
                border-radius: 12px;
            }

                textarea.form-control:focus, select.form-select:focus {
                    background-color: var(--surface-2);
                    border-color: var(--accent);
                    color: #e0e0f0;
                    box-shadow: 0 0 0 3px rgba(110,168,254,0.2);
                }

            #loadingOverlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(13,13,31,0.85);
                z-index: 9999;
                justify-content: center;
                align-items: center;
                flex-direction: column;
                gap: 1rem;
            }

            footer {
                border-top: 1px solid var(--border);
                padding: 1.5rem 0;
                color: #6b7280;
                font-size: 0.85rem;
            }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #1e1e2e; border-bottom: 1px solid #3a3a5c;">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <span class="brand-icon">🔬</span>
                <span class="brand-text">Hypothesis Generator</span>
            </a>
            <div class="ms-auto d-flex align-items-center gap-2">
                <button id="themeToggle" class="btn btn-sm btn-outline-secondary rounded-pill px-3"
                        onclick="toggleTheme()" title="Toggle light/dark mode">
                    <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
                </button>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <div id="loadingOverlay">
        <div class="spinner-border text-primary" style="width:3rem;height:3rem;" role="status"></div>
        <p class="text-light fs-5 fw-semibold">Generating hypotheses with AI...</p>
        <p class="text-secondary small">This usually takes 3–8 seconds</p>
    </div>

    <footer class="text-center">
        <div class="container">
            Built by Theodor_de and Claude &nbsp;•&nbsp; Powered by Groq AI &nbsp;•&nbsp; ASP.NET Core 8
        </div>
    </footer>

    <!-- Cookie Consent Banner -->
    <div id="cookieBanner"
         style="display:none; position:fixed; bottom:0; left:0; right:0; z-index:99999;
        background:#1e1e2e; border-top:1px solid #3a3a5c; padding:1rem 1.5rem;">
        <div class="container d-flex align-items-center justify-content-between flex-wrap gap-3">
            <p class="mb-0 text-secondary small" style="max-width:700px;">
                <i class="bi bi-shield-check me-1" style="color:var(--accent);"></i>
                We collect <strong class="text-light">anonymous usage data</strong> (search topic, difficulty, language)
                to improve this tool. No personal information is collected.
            </p>
            <div class="d-flex gap-2">
                <button onclick="setCookieConsent('declined')"
                        class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                    Decline
                </button>
                <button onclick="setCookieConsent('accepted')"
                        class="btn btn-sm rounded-pill px-3"
                        style="background:linear-gradient(135deg,#6ea8fe,#a78bfa); border:none; color:#fff;">
                    Accept
                </button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleTheme() {
        const html = document.documentElement;
        const icon = document.getElementById('themeIcon');
        const isLight = html.getAttribute('data-bs-theme') === 'light';

        if (isLight) {
        html.setAttribute('data-bs-theme', 'dark');
        icon.className = 'bi bi-moon-stars-fill';
        html.style.setProperty('--accent', '#6ea8fe');
        html.style.setProperty('--accent-soft', '#1a2942');
        html.style.setProperty('--surface', '#1e1e2e');
        html.style.setProperty('--surface-2', '#2a2a3e');
        html.style.setProperty('--border', '#3a3a5c');
        document.body.style.backgroundColor = '#13131f';
        document.body.style.color = '#e0e0f0';
        } else {
        html.setAttribute('data-bs-theme', 'light');
        icon.className = 'bi bi-sun-fill';
        html.style.setProperty('--accent', '#2563eb');
        html.style.setProperty('--accent-soft', '#dbeafe');
        html.style.setProperty('--surface', '#ffffff');
        html.style.setProperty('--surface-2', '#f1f5f9');
        html.style.setProperty('--border', '#cbd5e1');
        document.body.style.backgroundColor = '#f8fafc';
        document.body.style.color = '#1e293b';
        }
        }

        function showLoading() {
        document.getElementById('loadingOverlay').style.display = 'flex';
        }

        function setCookieConsent(value) {
        const expires = new Date();
        expires.setFullYear(expires.getFullYear() + 1);
        document.cookie = `cookieConsent=${value}; expires=${expires.toUTCString()}; path=/`;
        document.getElementById('cookieBanner').style.display = 'none';
        }

        function getCookie(name) {
        const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
        return match ? match[2] : null;
        }

        window.addEventListener('load', function () {
        if (!getCookie('cookieConsent')) {
        document.getElementById('cookieBanner').style.display = 'block';
        }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>